<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="#3F6EDC"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"/>

        <TextView
            android:text="Bus Registration"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Route Spinner (UPDATED) -->
    <Spinner
        android:id="@+id/routeSpinner"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="@color/white"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bus Fee Card -->
    <LinearLayout
        android:id="@+id/busFeeCard"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/routeSpinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="Bus Fee"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <!-- UPDATED ID -->
        <TextView
            android:id="@+id/busFee"
            android:text="₹ 0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#3F6EDC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Payment Status -->
    <LinearLayout
        android:id="@+id/paymentCard"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/busFeeCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="Payment Status:"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <!-- UPDATED ID -->
        <TextView
            android:id="@+id/paymentStatus"
            android:text="Unpaid"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Register Button -->
    <Button
        android:id="@+id/registerBusBtn"
        android:text="Register Bus"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:backgroundTint="#3F6EDC"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="30dp"
        app:layout_constraintTop_toBottomOf="@id/paymentCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>