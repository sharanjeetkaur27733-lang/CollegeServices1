<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB">

    <!-- Header -->

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="#3F6EDC"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
           />

        <TextView
            android:text="Leave Application"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Reason -->

    <EditText
        android:id="@+id/reason"
        android:hint="Reason"
        android:textColorHint="@color/black"
        android:background="@color/white"
        android:padding="14dp"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- From Date -->

    <!-- To Date -->

    <EditText
        android:id="@+id/fromDate"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="@color/white"
        android:hint="From Date"
        android:textColorHint="@color/black"
        android:padding="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reason" />

    <EditText
        android:id="@+id/toDate"
        android:hint="To Date"
        android:textColorHint="@color/black"
        android:background="@color/white"
        android:padding="14dp"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/fromDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Submit Button -->

    <Button
        android:id="@+id/submitLeave"
        android:text="Submit Leave"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:backgroundTint="#3F6EDC"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="30dp"
        app:layout_constraintTop_toBottomOf="@id/toDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>