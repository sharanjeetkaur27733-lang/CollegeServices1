<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#3F6EDC"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backArrow"
            android:src="@drawable/ic_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            />

        <TextView
            android:text="Fee Payment"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Spinner -->
    <Spinner
        android:id="@+id/routeSpinner"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_margin="20dp"

        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Fee Card -->
    <LinearLayout
        android:id="@+id/feeCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="6dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/routeSpinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="Total Fee"
            android:textSize="14sp"
            android:textColor="#7F8C8D"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/totalFee"
            android:text="₹ 0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>

        <TextView
            android:id="@+id/paidFee"
            android:text="Paid: ₹ 0"
            android:textSize="16sp"
            android:textColor="#27AE60"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/dueFee"
            android:text="Due: ₹ 0"
            android:textSize="16sp"
            android:textColor="#E67E22"
            android:layout_marginTop="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="16dp"
            android:progress="0"
            android:progressTint="#3F6EDC"/>

    </LinearLayout>

    <!-- Pay Button -->
    <Button
        android:id="@+id/payBtn"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="30dp"
        android:backgroundTint="#3F6EDC"
        android:text="Pay Now"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/feeCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- History Button -->
    <Button
        android:id="@+id/historyBtn"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="#E9EDF7"
        android:text="View History"
        android:textColor="#3F6EDC"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/payBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>